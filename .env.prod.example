# ════════════════════════════════════════════════════════════════════════════
#  Nexus Support Agent — PRODUCTION env for docker-compose.prod.yml
#  Copy to ".env" on the server and fill in real values. NEVER commit .env.
#  cp .env.prod.example .env
# ════════════════════════════════════════════════════════════════════════════

# ── App database (pgvector, runs as the "db" compose service) ────────────────
# Strong random password. Generate: python -c "import secrets;print(secrets.token_urlsafe(24))"
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Auth ─────────────────────────────────────────────────────────────────────
# Strong random secret (the app refuses known-weak values).
# Generate: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_char_hex_secret

# First admin user, seeded automatically on first startup.
ADMIN_EMAIL=admin@nexusqtech.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Allow guest (no-login) access to the chat. true | false
ALLOW_ANONYMOUS=true

# ── Gemini (LLM via Vertex AI) — required even with local embeddings ─────────
# Put the service-account JSON at ./gcp-credentials.json (mounted read-only).
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# ── Public origin & ports ────────────────────────────────────────────────────
# The exact origin users hit through IIS. Baked into the frontend at build time.
# Include the port unless IIS serves Nexus on 443.
#   e.g. https://app-nexusqtech.com:8443   (dedicated free HTTPS port)
PUBLIC_ORIGIN=https://app-nexusqtech.com:8443

# Localhost port the Docker nginx binds to (IIS proxies here). Must be FREE.
# VGD already uses 8080 — pick another free port and match it in iis/web.config.
NGINX_HOST_PORT=8082
