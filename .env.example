# ════════════════════════════════════════════════════════════
#  LOCAL DEV  (docker-compose — no API keys needed)
# ════════════════════════════════════════════════════════════
# GCP credentials are mounted from your local gcloud config automatically.
# Just make sure you have run: gcloud auth application-default login

# Providers — already set in docker-compose, listed here for reference
# AUTH_PROVIDER=local
# STORAGE_PROVIDER=local
# EMBEDDING_PROVIDER=local
# EMBEDDING_DIMENSIONS=384
# LOCAL_JWT_SECRET=local-dev-secret

# ════════════════════════════════════════════════════════════
#  PRODUCTION  (Cloud Run — set these in Secret Manager)
# ════════════════════════════════════════════════════════════
# AUTH_PROVIDER=firebase
# STORAGE_PROVIDER=gcs
# EMBEDDING_PROVIDER=vertexai
# EMBEDDING_DIMENSIONS=768

# FIREBASE_PROJECT_ID=nexus-support-agent
# VERTEX_AI_PROJECT=nexus-support-agent
# VERTEX_AI_LOCATION=us-central1
# GCS_BUCKET_NAME=nexus-support-agent-docs
# DATABASE_URL=postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/...

# Frontend (production)
# NEXT_PUBLIC_API_URL=https://nexus-backend-xxx-uc.a.run.app
# NEXT_PUBLIC_LOCAL_DEV=false
# NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nexus-support-agent.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=nexus-support-agent
