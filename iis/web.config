<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS ARR reverse-proxy config for the Nexus Support Agent.

  This server already runs other IIS apps (e.g. VGD on :80/:443 and Docker
  nginx on localhost:8080). Nexus MUST stay isolated:
    - Place this web.config ONLY in the physical folder of the Nexus IIS site.
    - Give the Nexus site its OWN Application Pool.
    - Bind the Nexus site to a FREE HTTPS port (NOT 443 — VGD uses it), e.g. 8443.
    - Never copy this file into, or edit, any other site's folder.

  Prerequisites (already installed on this server for VGD — do NOT reconfigure
  the global ARR proxy setting, it is shared):
    - IIS Application Request Routing 3.0
    - IIS URL Rewrite 2.1
    - ARR "Enable proxy" is already ON at the server node.

  IIS site setup for Nexus:
    - Binding: HTTPS port <FREE_PORT> (e.g. 8443), hostname app-nexusqtech.com,
      with the cert for app-nexusqtech.com assigned.
    - Physical path: any empty folder (content is served by Docker, not IIS).

  IMPORTANT: update the proxy target port below if NGINX_HOST_PORT in .env is
  not 8082. The browser-facing port lives in the IIS binding, not here.

  Flow: Browser → IIS :<FREE_PORT> (TLS) → localhost:8082 (Docker nginx) → app
-->
<configuration>
    <system.webServer>

        <rewrite>
            <rules>

                <!-- 1. Redirect any plain-HTTP hit on this site to HTTPS -->
                <rule name="HTTP to HTTPS Redirect" enabled="true" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{HTTPS}" pattern="^OFF$" ignoreCase="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}"
                            redirectType="Permanent" />
                </rule>

                <!-- 2. Reverse proxy to the Nexus Docker nginx (localhost only).
                     Change 8082 if NGINX_HOST_PORT differs. -->
                <rule name="Reverse Proxy to Nexus Docker" enabled="true" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://localhost:8082/{R:1}" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="https" />
                    </serverVariables>
                </rule>

            </rules>
        </rewrite>

        <httpProtocol>
            <customHeaders>
                <add name="Strict-Transport-Security"
                     value="max-age=31536000; includeSubDomains" />
                <remove name="X-Powered-By" />
            </customHeaders>
        </httpProtocol>

        <security>
            <requestFiltering removeServerHeader="true">
                <!-- Match the nginx/backend upload cap (100 MB + headroom). -->
                <requestLimits maxAllowedContentLength="110000000" />
            </requestFiltering>
        </security>

    </system.webServer>
</configuration>
